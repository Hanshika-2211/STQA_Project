pipeline {
    agent any

    environment {
        PATH = "/Users/hanshikaanchan/.nvm/versions/node/v23.7.0/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${env.PATH}"
        JENKINS_NODE_COOKIE = 'dontKillMe'
    }

    stages {
        stage('Install App Dependencies & Start Services') {
            steps {
                script {
                    echo 'Installing backend and frontend dependencies...'
                    // Build & start backend in background
                    dir('app/backend') {
                        sh 'npm install'
                        sh 'nohup npm start > backend.log 2>&1 &'
                    }
                    // Build & start frontend in background
                    dir('app/frontend') {
                        sh 'npm install'
                        sh 'nohup npm run dev > frontend.log 2>&1 &'
                    }
                    // Wait for the servers to spin up
                    sh 'sleep 10'
                }
            }
        }

        stage('Run Selenium Tests') {
            steps {
                dir('selenium-tests') {
                    // Run Maven test suite
                    sh 'mvn clean test'
                }
            }
        }
    }

    post {
        always {
            // Kill background services to free up ports
            sh 'pkill -f "node server.js" || true'
            sh 'pkill -f "vite" || true'
            
            // Publish TestNG Results for TestNG Reports Analyzer dashboard integration
            testNG pattern: 'selenium-tests/target/surefire-reports/testng-results.xml'
        }
    }
}
